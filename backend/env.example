PORT=3001
FRONTEND_URL=http://localhost:5173
NODE_ENV=development

# Database connection string for Neon Postgres
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=

# Optional: Custom filenames for data downloads
# Use these when the automated download link is broken
# CUSTOM_NATION_STATS_FILE=CyberNations_SE_Nation_Stats_10142025510001.zip
# CUSTOM_AID_STATS_FILE=CyberNations_SE_Aid_Stats_10142025520001.zip
# CUSTOM_WAR_STATS_FILE=CyberNations_SE_War_Stats_10142025525001.zip

# Cron job security (optional)
# If set, cron endpoints will require this token in Authorization header
# If not set, endpoints will only accept requests with x-vercel-cron header
# CRON_SECRET=your-secret-token-here

# Discord OAuth
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Full callback URL (must match exactly what's configured in the Discord developer portal).
# In production, this MUST point at the FRONTEND domain — the frontend's
# vercel.json rewrites /api/* to the backend so that the session cookie ends
# up first-party on the frontend domain (mobile Safari blocks third-party cookies).
# Development: http://localhost:3001/api/auth/discord/callback
# Production:  https://cybernations-frontend.vercel.app/api/auth/discord/callback
DISCORD_CALLBACK_URL=http://localhost:3001/api/auth/discord/callback
# Backend base URL (used if DISCORD_CALLBACK_URL is just a path)
BACKEND_URL=http://localhost:3001

# Session configuration
SESSION_SECRET=your-strong-random-session-secret-min-32-chars
# SESSION_NAME=sessionId
SESSION_MAX_AGE=2592000000
COOKIE_SECURE=false
