{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://cybernations-backend.vercel.app/api/:path*"
    },
    {
      "source": "/((?!.*\\..*|api).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/((?!api/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
